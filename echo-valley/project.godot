; Engine configuration file.
; It's best edited using the editor UI and not directly,
; since the parameters that go here are not all obvious.
;
; Format:
;   [section] ; section goes between []
;   param=value ; assign values to parameters

config_version=5

[application]

config/name="Harmona Valley"
config/description="A cozy pixel-art creature-collection RPG. Catch Harmons, uncover The Fracture, and restore The Chorus."
config/version="0.1.0"
run/main_scene="res://scenes/boot/loading.tscn"
config/features=PackedStringArray("4.7", "GL Compatibility")
config/icon="res://assets/echoes/emberkit.png"

[autoload]

EventBus="*res://scripts/autoload/event_bus.gd"
GameStrings="*res://scripts/autoload/game_strings.gd"
EchoCatalog="*res://scripts/autoload/echo_catalog.gd"
ItemCatalog="*res://scripts/autoload/item_catalog.gd"
GameState="*res://scripts/autoload/game_state.gd"
SaveService="*res://scripts/autoload/save_service.gd"
StoryService="*res://scripts/autoload/story_service.gd"
SceneRouter="*res://scripts/autoload/scene_router.gd"
VersusNet="*res://scripts/autoload/versus_net.gd"
TouchUtil="*res://scripts/ui/touch_util.gd"
TouchControls="*res://scripts/ui/touch_controls.gd"

[display]

window/size/viewport_width=240
window/size/viewport_height=160
window/size/window_width_override=960
window/size/window_height_override=640
window/stretch/mode="canvas_items"
window/stretch/aspect="expand"
window/stretch/scale_mode="fractional"
window/handheld/orientation=0

