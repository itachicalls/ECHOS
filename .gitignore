# Godot 4+ ignore rules
.godot/
*.translation
export.cfg
export_presets.cfg
*.tmp

# OS
.DS_Store
Thumbs.db

# IDE
.vscode/
.idea/
*.user
*.suo

# Builds
exports/
node_modules/
*.apk
*.aab
*.ipa
*.exe
*.pck

# Ignore all build output EXCEPT the root web export, which Vercel serves statically.
/build/*
!/build/web/
!/build/web/**

# Stray/duplicate export dir and local tool logs (not for deploy).
echo-valley/build/
echo-valley/tools/*.txt
