; Echoheart — cozy low-poly Echo collection RPG
; Engine: Godot 4.7

config_version=5

[application]

config/name="Echoheart"
config/description="A cozy low-poly creature-collection RPG. Discover Echoes, train them, and battle with friends."
config/version="0.1.0"
run/main_scene="res://scenes/boot/boot.tscn"
config/features=PackedStringArray("4.7", "Forward Plus")
config/icon="res://assets/ui/icon.svg"

[autoload]

EventBus="*res://scripts/autoload/event_bus.gd"
EchoCatalog="*res://scripts/autoload/echo_catalog.gd"
GameState="*res://scripts/autoload/game_state.gd"
SaveService="*res://scripts/autoload/save_service.gd"
SceneRouter="*res://scripts/autoload/scene_router.gd"

[display]

window/size/viewport_width=1280
window/size/viewport_height=720
window/stretch/mode="canvas_items"
window/stretch/aspect="expand"
window/handheld/orientation=1

